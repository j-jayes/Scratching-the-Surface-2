# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# NEVER commit real credentials.

# ── Azure ────────────────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=
AZURE_LOCATION=westeurope
AZURE_RESOURCE_GROUP=cascade-defect-rg
AZURE_ENV_NAME=dev

# ── Azure Storage (Blob) ─────────────────────────────────────────────────────
# Account name only (no key); auth via az login / managed identity.
BLOB_ACCOUNT=
BLOB_CONTAINER_RAW=raw
BLOB_CONTAINER_PROCESSED=processed
BLOB_CONTAINER_MODELS=models
BLOB_CONTAINER_SPLITS=splits

# ── Azure OpenAI (GPT-4o vision) ─────────────────────────────────────────────
AOAI_ENDPOINT=
AOAI_API_VERSION=2024-08-01-preview
AOAI_DEPLOYMENT=gpt-4o
AOAI_DEPLOYMENT_GPT4O=gpt-4o
# Prefer Entra (az login) over key auth. Leave AOAI_API_KEY blank if using AAD.
AOAI_API_KEY=

# ── Azure Container Registry / Container Apps ────────────────────────────────
ACR_NAME=
ACA_ENVIRONMENT=cascade-defect-env

# ── Kaggle ───────────────────────────────────────────────────────────────────
# Get from https://www.kaggle.com/settings (Create New API Token).
KAGGLE_USERNAME=
KAGGLE_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Native OpenAI Key
NATIVE_OPENAI_API_KEY=


GCP_EMAIL=
GCP_PROJECT_ID=